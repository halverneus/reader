import { Button, LineEdit, ScrollView, ComboBox } from "std-widgets.slint";

export struct GridRow {
    marker: int,
    has-actor: bool,
    actor-event-idx: int,
    actor-name: string,
    actor-text: string,
    actor-mode: string,
    has-editor: bool,
    editor-text: string,
    editor-end-marker: int,
    has-keys: bool,
    keys-display: string,
    keys-active: bool,
}

export struct ActorRow {
    marker: int,
    end-marker: int,
    event-idx: int,
    actor: string,
    text: string,
    mode: string,
}

export struct EditorRow {
    marker: int,
    end-marker: int,
    text: string,
}

export struct KeysRow {
    marker: int,
    end-marker: int,
    display: string,
    running: bool,
}

export struct ActorEntry {
    name: string,
    voice: string,
    mode: string,
}

export component AppWindow inherits Window {
    title: "Script Reader";
    preferred-width: 1400px;
    preferred-height: 800px;
    background: #12121e;

    in-out property <[ActorEntry]>  actors: [];
    in-out property <[string]>      voices: [];
    in-out property <string>        file-path: "";
    in-out property <int>           playing-index: -1;
    in-out property <bool>          model-ready: false;
    in-out property <bool>          production-mode: false;
    in-out property <string>        prod-status: "";
    in-out property <bool>          sidebar-visible: true;

    in-out property <[GridRow]>     grid-rows: [];
    in-out property <[ActorRow]>    actor-rows: [];
    in-out property <[EditorRow]>   editor-rows: [];
    in-out property <[KeysRow]>     prod-keys-rows: [];

    in-out property <int>           prod-actor-idx: -1;
    in-out property <float>         prod-actor-scroll: 0;
    in-out property <int>           prod-editor-idx: -1;
    in-out property <float>         prod-editor-scroll: 0;
    in-out property <int>           prod-keys-idx: -1;
    in-out property <float>         prod-keys-scroll: 0;
    in-out property <int>           prod-keys-step: -1;

    callback open-file-dialog();
    callback load-file(string);
    callback advance-block();
    callback rewind-block();
    callback toggle-mode();
    callback reset-production();
    callback actor-event-clicked(int);
    callback actor-voice-changed(string, string);
    callback actor-mode-cycled(string);
    callback actor-prev-voice(string);
    callback actor-next-voice(string);
    callback preview-voice(string);

    forward-focus: key-scope;

    key-scope := FocusScope {
        key-released(event) => {
            if event.text == Key.DownArrow {
                root.advance-block();
                accept
            } else if event.text == Key.UpArrow {
                root.rewind-block();
                accept
            } else {
                reject
            }
        }

        VerticalLayout {
            padding: 0px;
            spacing: 0px;

            // ── Main content ──────────────────────────────────────────────────
            HorizontalLayout {
                padding: 0px;
                spacing: 0px;
                vertical-stretch: 1;

                // ── Three-pane area ───────────────────────────────────────────
                VerticalLayout {
                    horizontal-stretch: 1;
                    padding: 0px;
                    spacing: 0px;

                    // Pane headers
                    HorizontalLayout {
                        height: 30px;
                        padding: 0px;
                        spacing: 1px;

                        Rectangle {
                            horizontal-stretch: 1;
                            background: #0e0e1e;
                            Text {
                                text: "EDITOR NOTES";
                                color: #508060;
                                font-size: 10px; font-weight: 700; letter-spacing: 1.5px;
                                horizontal-alignment: center; vertical-alignment: center;
                            }
                        }
                        Rectangle { width: 1px; background: #1e1e30; }
                        Rectangle {
                            width: 600px;
                            background: #0e0e1e;
                            Text {
                                text: "ACTORS";
                                color: #5060c0;
                                font-size: 10px; font-weight: 700; letter-spacing: 1.5px;
                                horizontal-alignment: center; vertical-alignment: center;
                            }
                        }
                        Rectangle { width: 1px; background: #1e1e30; }
                        Rectangle {
                            horizontal-stretch: 1;
                            background: #0e0e1e;
                            Text {
                                text: "CODE / KEYSTROKES";
                                color: #906040;
                                font-size: 10px; font-weight: 700; letter-spacing: 1.5px;
                                horizontal-alignment: center; vertical-alignment: center;
                            }
                        }
                    }

                    Rectangle { height: 1px; background: #2a2a40; }

                    // ── Edit mode ─────────────────────────────────────────────
                    if !root.production-mode: ScrollView {
                        vertical-stretch: 1;
                        VerticalLayout {
                            spacing: 0px; padding: 0px;

                            for row in root.grid-rows: HorizontalLayout {
                                spacing: 0px; padding: 0px;

                                // Editor cell
                                Rectangle {
                                    horizontal-stretch: 1;
                                    clip: true;
                                    background: #131a14;

                                    if row.has-editor: HorizontalLayout {
                                        padding: 8px; spacing: 6px;
                                        Rectangle {
                                            width: 6px; height: 6px; y: 8px;
                                            border-radius: 3px; background: #305040;
                                        }
                                        VerticalLayout {
                                            spacing: 3px;
                                            HorizontalLayout {
                                                height: 14px; spacing: 3px; alignment: start;
                                                Text { text: row.marker; color: #2a3a2e; font-size: 9px; vertical-alignment: center; }
                                                Text { text: "–"; color: #1e2e22; font-size: 9px; vertical-alignment: center; }
                                                Text { text: row.editor-end-marker; color: #1e2e22; font-size: 9px; vertical-alignment: center; }
                                            }
                                            Text { text: row.editor-text; color: #90c0a0; font-size: 13px; wrap: word-wrap; }
                                        }
                                    }
                                    if !row.has-editor: Rectangle { background: transparent; min-height: 8px; }
                                }

                                Rectangle { width: 1px; background: #1e1e30; }

                                // Actor cell (fixed width)
                                Rectangle {
                                    width: 600px;
                                    clip: true;
                                    background: #14141f;

                                    if row.has-actor: edit-actor-ta := TouchArea {
                                        clicked => { root.actor-event-clicked(row.actor-event-idx); }
                                        Rectangle {
                                            background:
                                                root.playing-index == row.actor-event-idx ? #1e3060 :
                                                row.actor-mode == "skip" ? (edit-actor-ta.has-hover ? #2a1c06 : #201606) :
                                                edit-actor-ta.has-hover ? #1e1e30 : transparent;
                                            HorizontalLayout {
                                                padding: 8px; spacing: 6px;
                                                Rectangle {
                                                    width: 6px; height: 6px; y: 8px;
                                                    border-radius: 3px;
                                                    background:
                                                        root.playing-index == row.actor-event-idx ? #5de8a8 :
                                                        row.actor-mode == "skip" ? #c08030 : #3a3a5a;
                                                }
                                                VerticalLayout {
                                                    spacing: 3px;
                                                    HorizontalLayout {
                                                        height: 14px; spacing: 6px; alignment: start;
                                                        Text { text: row.marker; color: #2e2e45; font-size: 9px; vertical-alignment: center; }
                                                        Text {
                                                            text: row.actor-name;
                                                            color: row.actor-mode == "skip" ? #e89030 : #6a90e0;
                                                            font-size: 10px; font-weight: 700; vertical-alignment: center;
                                                        }
                                                        if row.actor-mode == "skip": Text {
                                                            text: "· YOUR LINE"; color: #c07828;
                                                            font-size: 9px; font-weight: 700; vertical-alignment: center;
                                                        }
                                                    }
                                                    Text {
                                                        text: row.actor-text;
                                                        color: row.actor-mode == "skip" ? #f0e0a0 : #c0c0d8;
                                                        font-size: 13px; wrap: word-wrap;
                                                    }
                                                }
                                            }
                                        }
                                    }
                                    if !row.has-actor: Rectangle { background: transparent; min-height: 8px; }
                                }

                                Rectangle { width: 1px; background: #1e1e30; }

                                // Keys cell
                                Rectangle {
                                    horizontal-stretch: 1;
                                    clip: true;
                                    background: #171410;

                                    if row.has-keys: HorizontalLayout {
                                        padding: 8px; spacing: 6px;
                                        Rectangle {
                                            width: 6px; height: 6px; y: 8px;
                                            border-radius: 3px;
                                            background: row.keys-active ? #e07820 : #3a3020;
                                        }
                                        VerticalLayout {
                                            spacing: 3px;
                                            Text { text: row.marker; color: #2e2818; font-size: 9px; height: 14px; vertical-alignment: center; }
                                            Text {
                                                text: row.keys-display;
                                                color: row.keys-active ? #f0c070 : #907850;
                                                font-size: 12px; wrap: word-wrap; font-family: "monospace";
                                            }
                                        }
                                    }
                                    if !row.has-keys: Rectangle { background: transparent; min-height: 8px; }
                                }
                            }

                            Rectangle { height: 200px; background: transparent; }
                        }
                    }

                    // ── Production mode ───────────────────────────────────────
                    if root.production-mode: HorizontalLayout {
                        vertical-stretch: 1;
                        spacing: 0px; padding: 0px;

                        // Editor pane
                        ScrollView {
                            horizontal-stretch: 1;
                            viewport-y: -root.prod-editor-scroll * 1px;
                            VerticalLayout {
                                spacing: 4px; padding: 4px;
                                for row[i] in root.editor-rows: Rectangle {
                                    border-radius: 4px;
                                    background:
                                        i == root.prod-editor-idx ? #141f16 :
                                        i < root.prod-editor-idx ? #0c120e : #0f1a10;
                                    border-width: i == root.prod-editor-idx ? 1px : 0px;
                                    border-color: #1e4028;
                                    opacity: i < root.prod-editor-idx ? 0.4 : 1.0;
                                    HorizontalLayout {
                                        padding: 6px; spacing: 5px;
                                        Rectangle {
                                            width: 3px; border-radius: 1.5px;
                                            background: i == root.prod-editor-idx ? #40a060 : #1e4028;
                                        }
                                        VerticalLayout {
                                            spacing: 3px; padding-left: 3px;
                                            HorizontalLayout {
                                                height: 13px; spacing: 3px; alignment: start;
                                                Text { text: row.marker; color: i == root.prod-editor-idx ? #385040 : #1e2e22; font-size: 9px; vertical-alignment: center; }
                                                Text { text: "–"; color: #1e2e22; font-size: 9px; vertical-alignment: center; }
                                                Text { text: row.end-marker; color: i == root.prod-editor-idx ? #385040 : #1e2e22; font-size: 9px; vertical-alignment: center; }
                                            }
                                            Text {
                                                text: row.text;
                                                color: i == root.prod-editor-idx ? #90c0a0 : #406050;
                                                font-size: 13px; wrap: word-wrap;
                                            }
                                        }
                                    }
                                }
                                Rectangle { height: 200px; background: transparent; }
                            }
                        }

                        Rectangle { width: 1px; background: #1e1e30; }

                        // Actor pane (fixed width)
                        ScrollView {
                            width: 600px;
                            viewport-y: -root.prod-actor-scroll * 1px;
                            VerticalLayout {
                                spacing: 4px; padding: 4px;
                                for row[i] in root.actor-rows: Rectangle {
                                    border-radius: 4px;
                                    background:
                                        i == root.prod-actor-idx ?
                                            (row.mode == "skip" ? #221608 : #141428) :
                                        i < root.prod-actor-idx ? #0c0c18 : #111120;
                                    border-width: i == root.prod-actor-idx ? 1px : 0px;
                                    border-color: row.mode == "skip" ? #604018 : #282858;
                                    opacity: i < root.prod-actor-idx ? 0.4 : 1.0;
                                    HorizontalLayout {
                                        padding: 6px; spacing: 5px;
                                        Rectangle {
                                            width: 3px; border-radius: 1.5px;
                                            background:
                                                root.playing-index == row.event-idx ? #5de8a8 :
                                                i == root.prod-actor-idx ?
                                                    (row.mode == "skip" ? #d09030 : #5050c0) :
                                                #1e1e38;
                                        }
                                        VerticalLayout {
                                            spacing: 3px; padding-left: 3px;
                                            HorizontalLayout {
                                                height: 14px; spacing: 5px; alignment: start;
                                                Text { text: row.marker; color: #2e2e45; font-size: 9px; vertical-alignment: center; }
                                                Text { text: "–"; color: #2a2a40; font-size: 9px; vertical-alignment: center; }
                                                Text { text: row.end-marker; color: #2e2e45; font-size: 9px; vertical-alignment: center; }
                                                Text {
                                                    text: row.actor;
                                                    color:
                                                        row.mode == "skip" ?
                                                            (i == root.prod-actor-idx ? #e89030 : #b07020) :
                                                        i == root.prod-actor-idx ? #88aaff : #4a6aaa;
                                                    font-size: 10px; font-weight: 700; vertical-alignment: center;
                                                }
                                                if row.mode == "skip" && i == root.prod-actor-idx: Text {
                                                    text: "· YOUR LINE"; color: #d08030;
                                                    font-size: 9px; font-weight: 700; vertical-alignment: center;
                                                }
                                            }
                                            Text {
                                                text: row.text;
                                                color:
                                                    row.mode == "skip" ?
                                                        (i == root.prod-actor-idx ? #f5e8b0 : #a09050) :
                                                    i == root.prod-actor-idx ? #e0e0f8 : #606080;
                                                font-size: 13px; wrap: word-wrap;
                                            }
                                        }
                                    }
                                }
                                Rectangle { height: 200px; background: transparent; }
                            }
                        }

                        Rectangle { width: 1px; background: #1e1e30; }

                        // Keys pane
                        ScrollView {
                            horizontal-stretch: 1;
                            viewport-y: -root.prod-keys-scroll * 1px;
                            VerticalLayout {
                                spacing: 4px; padding: 4px;
                                for row[i] in root.prod-keys-rows: Rectangle {
                                    border-radius: 4px;
                                    background:
                                        i == root.prod-keys-idx ?
                                            (row.running ? #1c1408 : #141210) :
                                        i < root.prod-keys-idx ? #0d0b08 : #10100c;
                                    border-width: i == root.prod-keys-idx ? 1px : 0px;
                                    border-color: row.running ? #604018 : #2a2018;
                                    opacity: i < root.prod-keys-idx ? 0.4 : 1.0;
                                    HorizontalLayout {
                                        padding: 6px; spacing: 5px;
                                        Rectangle {
                                            width: 3px; border-radius: 1.5px;
                                            background:
                                                i == root.prod-keys-idx ?
                                                    (row.running ? #f08020 : #504030) :
                                                #201c10;
                                            animate background { duration: 300ms; }
                                        }
                                        VerticalLayout {
                                            spacing: 3px; padding-left: 3px;
                                            HorizontalLayout {
                                                height: 13px; spacing: 4px; alignment: start;
                                                Text { text: row.marker; color: i == root.prod-keys-idx ? #403020 : #201c10; font-size: 9px; vertical-alignment: center; }
                                                Text { text: "–"; color: #201c10; font-size: 9px; vertical-alignment: center; }
                                                Text { text: row.end-marker; color: i == root.prod-keys-idx ? #403020 : #201c10; font-size: 9px; vertical-alignment: center; }
                                                if row.running: Text {
                                                    text: "RUNNING"; color: #f08020;
                                                    font-size: 9px; font-weight: 700; vertical-alignment: center;
                                                }
                                            }
                                            Text {
                                                text: row.display;
                                                color:
                                                    i == root.prod-keys-idx ?
                                                        (row.running ? #e0b060 : #706050) :
                                                    i < root.prod-keys-idx ? #403828 : #504030;
                                                font-size: 11px; wrap: word-wrap; font-family: "monospace";
                                            }
                                        }
                                    }
                                }
                                Rectangle { height: 200px; background: transparent; }
                            }
                        }
                    }
                }

                // ── Character sidebar (collapsible) ───────────────────────────
                Rectangle {
                    width: root.sidebar-visible ? 220px : 0px;
                    clip: true;
                    background: #0e0e18;
                    animate width { duration: 200ms; }

                    ScrollView {
                        VerticalLayout {
                            padding: 12px; spacing: 16px; alignment: start;

                            Text {
                                text: "CHARACTERS";
                                color: #2e2e45; font-size: 10px; font-weight: 700;
                                letter-spacing: 1.5px;
                            }

                            if root.actors.length == 0: Text {
                                text: "Load a script to see\ncharacters here.";
                                color: #252535; font-size: 12px; wrap: word-wrap;
                            }

                            for actor in root.actors: VerticalLayout {
                                spacing: 5px;

                                HorizontalLayout {
                                    spacing: 6px; height: 24px;
                                    Text {
                                        text: actor.name;
                                        color:
                                            actor.mode == "hide" ? #252535 :
                                            actor.mode == "skip" ? #c08020 : #90b0f0;
                                        font-size: 12px; font-weight: 700;
                                        vertical-alignment: center; horizontal-stretch: 1;
                                    }
                                    actor-mode-ta := TouchArea {
                                        width: 46px; height: 20px;
                                        clicked => { root.actor-mode-cycled(actor.name); }
                                        Rectangle {
                                            border-radius: 3px;
                                            background:
                                                actor.mode == "read" ? #0a2818 :
                                                actor.mode == "skip" ? #281a08 : #200818;
                                            border-width: 1px;
                                            border-color:
                                                actor.mode == "read" ? #206040 :
                                                actor.mode == "skip" ? #604018 : #501030;
                                            Text {
                                                text:
                                                    actor.mode == "read" ? "READ" :
                                                    actor.mode == "skip" ? "SKIP" : "HIDE";
                                                color:
                                                    actor.mode == "read" ? #40c070 :
                                                    actor.mode == "skip" ? #c08030 : #c03050;
                                                font-size: 9px; font-weight: 700;
                                                horizontal-alignment: center; vertical-alignment: center;
                                            }
                                        }
                                    }
                                }

                                HorizontalLayout {
                                    spacing: 2px; height: 26px;
                                    prev-ta := TouchArea {
                                        width: 20px; enabled: actor.mode != "hide";
                                        clicked => { root.actor-prev-voice(actor.name); }
                                        Rectangle {
                                            border-radius: 3px;
                                            background: prev-ta.has-hover ? #20203a : #181828;
                                            border-width: 1px; border-color: #28283e;
                                            Text {
                                                text: "◀"; font-size: 9px;
                                                color: actor.mode == "hide" ? #252535 : #6080b0;
                                                horizontal-alignment: center; vertical-alignment: center;
                                            }
                                        }
                                    }
                                    ComboBox {
                                        horizontal-stretch: 1; enabled: actor.mode != "hide";
                                        model: root.voices; current-value: actor.voice;
                                        selected(v) => { root.actor-voice-changed(actor.name, v); }
                                    }
                                    next-ta := TouchArea {
                                        width: 20px; enabled: actor.mode != "hide";
                                        clicked => { root.actor-next-voice(actor.name); }
                                        Rectangle {
                                            border-radius: 3px;
                                            background: next-ta.has-hover ? #20203a : #181828;
                                            border-width: 1px; border-color: #28283e;
                                            Text {
                                                text: "▶"; font-size: 9px;
                                                color: actor.mode == "hide" ? #252535 : #6080b0;
                                                horizontal-alignment: center; vertical-alignment: center;
                                            }
                                        }
                                    }
                                }

                                preview-ta := TouchArea {
                                    height: 18px; enabled: actor.mode != "hide";
                                    clicked => { root.preview-voice(actor.name); }
                                    Rectangle {
                                        border-radius: 3px;
                                        background: preview-ta.has-hover ? #182018 : #101410;
                                        border-width: 1px;
                                        border-color: actor.mode == "hide" ? #181828 : #204028;
                                        Text {
                                            text: "▶ PREVIEW";
                                            color: actor.mode == "hide" ? #252535 : #38904a;
                                            font-size: 9px; font-weight: 700;
                                            horizontal-alignment: center; vertical-alignment: center;
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }

            // ── Controls bar ─────────────────────────────────────────────────
            Rectangle {
                height: 50px;
                background: #0a0a14;
                border-color: #1e1e30; border-width: 1px;

                HorizontalLayout {
                    padding: 8px; spacing: 6px; alignment: start;

                    LineEdit {
                        width: 320px;
                        text <=> root.file-path;
                        placeholder-text: "Script file path (.yml)…";
                        accepted(text) => { root.load-file(text); }
                    }
                    Button { text: "Browse"; width: 72px; clicked => { root.open-file-dialog(); } }
                    Button { text: "Load"; width: 52px; clicked => { root.load-file(root.file-path); } }

                    HorizontalLayout {
                        width: 60px; spacing: 4px; alignment: center;
                        Rectangle {
                            width: 7px; height: 7px; border-radius: 3.5px;
                            background: root.model-ready ? #40c070 : #c04030;
                            animate background { duration: 400ms; }
                        }
                        Text {
                            text: root.model-ready ? "TTS" : "wait…";
                            color: root.model-ready ? #30a050 : #804030;
                            font-size: 10px; vertical-alignment: center;
                            animate color { duration: 400ms; }
                        }
                    }

                    Rectangle { width: 1px; background: #2a2a40; }

                    ctrl-mode-ta := TouchArea {
                        width: 140px;
                        clicked => { root.toggle-mode(); }
                        Rectangle {
                            border-radius: 4px;
                            background: root.production-mode ? #0a2818 : #0a0a2e;
                            border-width: 1px;
                            border-color: root.production-mode ? #20603a : #202068;
                            Text {
                                text: root.production-mode ? "← Edit Mode" : "Production Mode →";
                                color: root.production-mode ? #40c070 : #5060d0;
                                font-size: 10px; font-weight: 700;
                                horizontal-alignment: center; vertical-alignment: center;
                            }
                        }
                    }

                    reset-ta := TouchArea {
                        width: 58px; enabled: root.production-mode;
                        clicked => { root.reset-production(); }
                        Rectangle {
                            border-radius: 4px;
                            background: (reset-ta.has-hover && root.production-mode) ? #280a0a : #1a0808;
                            border-width: 1px;
                            border-color: root.production-mode ? #501818 : #201010;
                            Text {
                                text: "Reset";
                                color: root.production-mode ? #c04040 : #301818;
                                font-size: 10px; font-weight: 700;
                                horizontal-alignment: center; vertical-alignment: center;
                            }
                        }
                    }

                    sidebar-ta := TouchArea {
                        width: 68px;
                        clicked => { root.sidebar-visible = !root.sidebar-visible; }
                        Rectangle {
                            border-radius: 4px;
                            background: sidebar-ta.has-hover ? #181828 : #101018;
                            border-width: 1px; border-color: #252535;
                            Text {
                                text: root.sidebar-visible ? "◀ Voices" : "▶ Voices";
                                color: #505068; font-size: 10px; font-weight: 700;
                                horizontal-alignment: center; vertical-alignment: center;
                            }
                        }
                    }

                    Text {
                        text: root.prod-status;
                        color: root.production-mode ? #606070 : #282830;
                        font-size: 11px; vertical-alignment: center; horizontal-stretch: 1;
                    }
                }
            }
        }
    }
}
